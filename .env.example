# ============================================================
# RangeBO Live Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
#
# cp .env.example .env
# ============================================================

# --- MetaTrader 5 ---
# Account number shown in the top-left of the MT5 terminal
MT5_LOGIN=12345678
# Your MT5 account password
MT5_PASSWORD=your_password_here
# Broker server name — visible on the MT5 login screen (e.g. ICMarkets-Live01)
MT5_SERVER=YourBroker-Live

# --- Telegram ---
# Get from @BotFather after creating a bot (/newbot command)
TELEGRAM_TOKEN=your_telegram_bot_token_here
# Your personal chat ID — visit:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# after sending any message to your bot, and find "chat":{"id": XXXXXXX}
TELEGRAM_CHAT_ID=your_chat_id_here
